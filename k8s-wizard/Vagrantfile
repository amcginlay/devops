Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"

  config.vm.provider "parallels" do |prl|
    prl.memory = 8192
    prl.cpus = 4
  end

  config.vm.hostname = "ubuntu2404"
  config.vm.network "forwarded_port", guest: 6443, host: 6443
  config.vm.network "forwarded_port", guest: 443, host: 443
  config.vm.synced_folder ".", "/vagrant", type: "rsync"

  config.vm.provision "shell", inline: <<-SHELL
    set -e

    echo "==> Installing Docker..."
    apt-get update
    apt-get install -y ca-certificates curl gnupg
    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg --yes
    chmod a+r /etc/apt/keyrings/docker.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $VERSION_CODENAME) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null
    apt-get update
    apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    usermod -aG docker vagrant

    echo "==> Installing kubectl..."
    curl -fsSL "https://dl.k8s.io/release/$(curl -fsSL https://dl.k8s.io/release/stable.txt)/bin/linux/arm64/kubectl" -o /tmp/kubectl
    install -o root -g root -m 0755 /tmp/kubectl /usr/local/bin/kubectl

    echo "==> Installing helm..."
    curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

    echo "==> Installing kind..."
    curl -fsSL https://kind.sigs.k8s.io/dl/latest/kind-linux-arm64 -o /tmp/kind
    install -o root -g root -m 0755 /tmp/kind /usr/local/bin/kind

    echo "==> Installing k9s..."
    curl -fsSL https://github.com/derailed/k9s/releases/latest/download/k9s_Linux_arm64.tar.gz -o /tmp/k9s.tar.gz
    tar -xzf /tmp/k9s.tar.gz -C /tmp k9s
    install -o root -g root -m 0755 /tmp/k9s /usr/local/bin/k9s

    echo "==> All tools installed successfully."

    echo "==> Creating kind cluster..."
    su - vagrant -c 'kind get clusters' | grep -q '^k8s-wizard$' || su - vagrant -c 'kind create cluster --name k8s-wizard --config /vagrant/manifests/kind-cluster.yaml'
    echo "==> kind cluster created."

    echo "==> Installing cert-manager..."
    su - vagrant -c 'helm repo add jetstack https://charts.jetstack.io --force-update'
    su - vagrant -c 'helm upgrade --install cert-manager jetstack/cert-manager --namespace cert-manager --create-namespace --set crds.enabled=true --wait'

    echo "==> Creating self-signed ClusterIssuer..."
    su - vagrant -c 'kubectl apply -f /vagrant/manifests/selfsigned-clusterissuer.yaml'

    echo "==> Installing Gateway API CRDs..."
    su - vagrant -c 'kubectl apply -f https://github.com/kubernetes-sigs/gateway-api/releases/latest/download/standard-install.yaml'

    echo "==> Installing Nginx Gateway Fabric..."
    su - vagrant -c 'helm upgrade --install nginx-gateway oci://ghcr.io/nginx/charts/nginx-gateway-fabric --namespace nginx-gateway --create-namespace --set service.type=NodePort --set "service.ports[0].nodePort=30443" --wait'

    echo "==> Creating default Gateway with TLS..."
    su - vagrant -c 'kubectl apply -f /vagrant/manifests/default-gateway.yaml'

    echo "==> Gateway API setup complete."
  SHELL
end
